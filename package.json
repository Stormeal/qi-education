{
  "name": "qi-education",
  "version": "0.1.18",
  "private": true,
  "scripts": {
    "app:dev": "concurrently -k -n api,app -c blue,green \"npm run api:dev\" \"npm run app:dev:frontend\"",
    "app:dev:frontend": "npm --prefix app start",
    "app:build": "npm --prefix app run build",
    "app:build:pages": "npm --prefix app run build -- --base-href /qi-education/ --deploy-url /qi-education/",
    "app:test": "npm --prefix app test",
    "api:dev": "npm --prefix api run dev",
    "api:build": "npm --prefix api run build",
    "api:test": "npm --prefix api test",
    "env:pull": "npx vercel env pull api/.env --environment=development --yes"
  },
  "workspaces": [
    "app",
    "api"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
