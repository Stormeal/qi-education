{
  "name": "qi-education",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "app:dev": "npm --prefix app start",
    "app:build": "npm --prefix app run build",
    "app:build:pages": "npm --prefix app run build -- --base-href /qi-education/ --deploy-url /qi-education/",
    "app:test": "npm --prefix app test",
    "api:dev": "npm --prefix api run dev",
